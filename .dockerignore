# Never bake secrets into the image
backend/.env
.env
.env.*

# Client build outputs — too large, regenerated at runtime
builds/

# Node modules — reinstalled inside container
node_modules/
backend/node_modules/
site-builder/node_modules/

# Build artifacts
backend/dist/
site-builder/dist/

# Mac/Editor junk
.DS_Store
.idea/
*.swp

# Git history
.git/

# Claude Code settings (contains API keys)
.claude/settings.json
.claude/settings.local.json
