# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Optional: restrict bot to a specific chat/group ID (leave empty to allow all)
# To get your chat ID: add @userinfobot to your group, it will post the chat ID
TELEGRAM_ALLOWED_CHAT_ID=

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Firecrawl ────────────────────────────────────────────────────────────────
# Get from https://firecrawl.dev
FIRECRAWL_API_KEY=

# ─── 21st.dev Magic ───────────────────────────────────────────────────────────
# Get from https://21st.dev
TWENTY_FIRST_API_KEY=

# ─── Paths ────────────────────────────────────────────────────────────────────
# Absolute path to the root of the WEB DEVELOPER AGENT project
# Local (Mac):      PROJECT_ROOT=/Users/yourname/path/to/WEB DEVELOPER AGENT
# Production VPS:   PROJECT_ROOT=/var/www/wd01
# Docker/Railway:   PROJECT_ROOT=/app
PROJECT_ROOT=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
